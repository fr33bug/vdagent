# DeepSeek API Configuration
# Get your API key from https://platform.deepseek.com/
DEEPSEEK_API_KEY=GZQKEY  # Replace with your actual API key
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# IDA Pro Configuration (optional)
# Path to IDA Pro executable (e.g., /usr/local/bin/ida64)
IDA_PATH=/path/to/ida64

# Ghidra Configuration (optional)
# Path to Ghidra installation directory
GHIDRA_PATH=/path/to/ghidra_10.3.3_PUBLIC
# Directory for Ghidra projects (optional)
GHIDRA_PROJECTS_DIR=/path/to/ghidra_projects

# Analysis Settings
# Maximum number of functions to analyze per binary
MAX_FUNCTIONS_PER_ANALYSIS=100
# Maximum pseudocode length to send to AI (characters)
MAX_PSEUDOCODE_LENGTH=10000

# Output Settings
# Directory for analysis reports
OUTPUT_DIR=./output
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Cache Settings
# Cache AI analysis results to reduce API costs
USE_CACHE=true
# Directory for cache files
CACHE_DIR=./cache